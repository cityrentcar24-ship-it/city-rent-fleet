# Скопируйте этот файл в .env.local и заполните своими значениями
# (для локального запуска — на Vercel эти же переменные задаются в настройках проекта)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Пароль для входа в приложение (один на всех сотрудников)
VITE_APP_PASSWORD=your-password-here
